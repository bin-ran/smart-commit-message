{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "outDir": "out",
    "lib": [
      "ESNext"
    ],
    "types": [
      "node",
      "vscode"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext"
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}