{
  "name": "smart-commit-message",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "binran",
  "license": "MIT",
  "icon": "icon.ico",
  "keywords": [
    "git",
    "commit",
    "ai",
    "smart-commit-message",
    "deepseek"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bin-ran/smart-commit-message.git"
  },
  "bugs": {
    "url": "https://github.com/bin-ran/smart-commit-message/issues"
  },
  "homepage": "https://github.com/bin-ran/smart-commit-message#readme",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartCommitMessage.generate",
        "title": "%command.generate.title%",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "smartCommitMessage.generate",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "smartCommitMessage.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.apiKey.description%"
        },
        "smartCommitMessage.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "%config.baseUrl.description%"
        },
        "smartCommitMessage.model": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "description": "%config.model.description%"
        },
        "smartCommitMessage.style": {
          "type": "string",
          "enum": [
            "conventional",
            "simple",
            "detailed"
          ],
          "default": "conventional",
          "description": "%config.style.description%"
        },
        "smartCommitMessage.language": {
          "type": "string",
          "enum": [
            "English",
            "Chinese"
          ],
          "default": "Chinese",
          "description": "%config.language.description%"
        },
        "smartCommitMessage.customPrompt": {
          "type": "string",
          "default": "",
          "description": "%config.customPrompt.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/vscode": "^1.120.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
